# ============================================================
# XRPL Credit Orchestrator — Environment Configuration
# ============================================================
# SECURITY: Never commit real values. Use secret management.

# --- infrastructure ---
PORT=3000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/xco

# --- auth ---
# REQUIRED: Generate with `openssl rand -hex 32`
AUTH_TOKEN_SECRET=
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=

# --- xrpl ---
XRPL_WS_URL=wss://s.devnet.rippletest.net:51233
XRPL_NETWORK=devnet
XRPL_LENDING_ENABLED=false

# --- ledger worker ---
LEDGER_WORKER_DRY_RUN=true
LEDGER_WORKER_POLL_MS=5000
LEDGER_WORKER_BATCH_SIZE=3

# --- signing ---
# Providers: env (DEV ONLY), file (DEV ONLY), aws-kms, gcp-kms, hsm
XRPL_SIGNER_PROVIDER=env

# DEV ONLY: JSON map of address → seed (NEVER use in production)
# Generate via: node scripts/devnet-fund.js
XRPL_SEEDS_JSON={}

# Production KMS:
# XRPL_SIGNER_PROVIDER=aws-kms
# XRPL_KMS_KEY_ALIAS=xco-signing-key

# --- rate limit ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
