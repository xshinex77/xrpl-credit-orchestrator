body{font-family:system-ui,sans-serif;background:#0b1020;color:#eef2ff;margin:0} header{padding:16px 20px;border-bottom:1px solid #24314f;background:#121933;position:sticky;top:0} .wrap{padding:20px;max-width:1200px;margin:0 auto}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:16px}.card{background:#121933;border:1px solid #24314f;border-radius:16px;padding:16px}.kpi{font-size:28px;font-weight:700} input,select,button,textarea{width:100%;padding:10px;border-radius:10px;border:1px solid #34476b;background:#0f172a;color:#eef2ff;box-sizing:border-box;margin-top:6px} button{cursor:pointer;background:#1d4ed8} pre{white-space:pre-wrap;word-break:break-word;background:#0a1223;padding:12px;border-radius:12px;max-height:320px;overflow:auto} a{color:#93c5fd} .row{display:grid;gap:10px}
