    await this.evidence.append('borrower', borrowerId, 'borrower.auth_linked', {
      actor: actor?.sub ?? null,
      action: 'link_auth_user',
      authUserId,
      borrowerId
    })
    return borrower
  }

  list() {
    return this.db.listBorrowers()
  }
}
